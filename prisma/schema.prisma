generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleKey {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

enum CustomerType {
  WHOLESALE
  RETAIL
  INSTITUTIONAL
}

enum AddressType {
  BILLING
  SHIPPING
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PICKING
  READY_FOR_DELIVERY
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum OrderChannel {
  B2B_PORTAL
  DIRECT_SALES
  SHOWROOM
  WHATSAPP
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  BANK_TRANSFER
  CHEQUE
  CARD
  WALLET
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN_IN
  RETURN_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGE
  TRANSFER_IN
  TRANSFER_OUT
  COUNT_CORRECTION
}

enum ExpenseCategory {
  OPERATIONS
  LOGISTICS
  MARKETING
  PAYROLL
  RENT
  UTILITIES
  OTHER
}

enum FulfillmentStatus {
  UNALLOCATED
  CONFIRMED
  PREPARING
  PICKING
  READY_FOR_PACKAGING
  READY_FOR_DISPATCH
  FULFILLED
  CANCELLED
  RETURNED
}

enum PackagingStatus {
  NOT_REQUIRED
  NOT_STARTED
  IN_PROGRESS
  PACKAGED
  LABELLED
  HANDED_TO_COURIER
}

enum DeliveryStatus {
  NOT_ASSIGNED
  ASSIGNED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum DeliveryMethod {
  STANDARD
  EXPRESS
  PICKUP_STORE
  COURIER_PARTNER
  INTERNAL_DRIVER
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
  REFUNDED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  EXPORTED
  LOGIN
  LOGOUT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum ReportType {
  SALES
  FINANCE
  INVENTORY
  CUSTOMER
  DELIVERY
}

model Role {
  id          Int      @id @default(autoincrement())
  key         RoleKey  @unique
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  phone            String?
  passwordHash     String?
  isActive         Boolean           @default(true)
  roleId           Int
  role             Role              @relation(fields: [roleId], references: [id])
  customerId       String?           @unique
  customer         Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lastLoginAt      DateTime?
  accounts         Account[]
  sessions         Session[]
  ordersCreated    Order[]           @relation("OrdersCreated")
  stockMovements   StockMovement[]   @relation("MovementsPerformed")
  paymentsReceived Payment[]         @relation("PaymentsReceived")
  recordedExpenses Expense[]         @relation("ExpensesRecorded")
  customerProfile  CustomerProfile?
  carts            Cart[]
  notifications    Notification[]
  auditLogs        AuditLog[]        @relation("AuditActor")
  createdReports   FinancialReport[] @relation("ReportsCreated")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  @@index([roleId])
  @@index([deletedAt])
}

model Customer {
  id               String           @id @default(cuid())
  code             String           @unique
  type             CustomerType     @default(WHOLESALE)
  companyName      String
  contactName      String
  email            String?
  phone            String
  alternatePhone   String?
  vatNumber        String?
  governorate      String?
  city             String?
  creditLimit      Decimal?         @db.Decimal(12, 2)
  paymentTermsDays Int              @default(0)
  lifetimeValue    Decimal          @default(0) @db.Decimal(14, 2)
  notes            String?
  isActive         Boolean          @default(true)
  user             User?
  profile          CustomerProfile?
  addresses        Address[]
  carts            Cart[]
  orders           Order[]
  invoices         Invoice[]
  deliveries       Delivery[]
  notifications    Notification[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  @@index([type, isActive])
  @@index([deletedAt])
}

model Address {
  id             String      @id @default(cuid())
  customerId     String
  customer       Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type           AddressType
  label          String
  contactName    String?
  phone          String?
  line1          String
  line2          String?
  city           String
  governorate    String
  postalCode     String?
  country        String      @default("Tunisia")
  isDefault      Boolean     @default(false)
  ordersShipping Order[]     @relation("ShippingAddress")
  ordersBilling  Order[]     @relation("BillingAddress")
  invoiceBilling Invoice[]   @relation("InvoiceBillingAddress")
  deliveries     Delivery[]  @relation("DeliveryAddress")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  @@index([customerId, type])
  @@index([deletedAt])
}

model Category {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  description    String?
  image          String?
  seoTitle       String?
  seoDescription String?
  isFeatured     Boolean    @default(false)
  sortOrder      Int        @default(0)
  parentId       String?
  parent         Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[] @relation("CategoryHierarchy")
  products       Product[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  @@index([parentId])
  @@index([deletedAt])
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  country     String?
  description String?
  logoUrl     String?
  website     String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Supplier {
  id                String            @id @default(cuid())
  code              String            @unique
  name              String
  slug              String            @unique
  contactName       String?
  email             String?
  phone             String?
  line1             String?
  city              String?
  governorate       String?
  isActive          Boolean           @default(true)
  paymentTermsDays  Int               @default(0)
  notes             String?
  preferredProducts Product[]         @relation("PreferredSupplier")
  offerings         SupplierProduct[]
  stockMovements    StockMovement[]
  expenses          Expense[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  @@index([deletedAt])
}

model Product {
  id                   String             @id @default(cuid())
  sku                  String             @unique
  barcode              String?
  slug                 String             @unique
  name                 String
  shortDescription     String?
  description          String?
  specifications       Json?
  tags                 String[]           @default([])
  unit                 String             @default("piece")
  packSize             Int                @default(1)
  minimumOrderQuantity Int                @default(1)
  stockOnHand          Int                @default(0)
  reservedStock        Int                @default(0)
  soldStock            Int                @default(0)
  costPrice            Decimal            @db.Decimal(10, 3)
  retailPrice          Decimal            @db.Decimal(10, 3)
  wholesalePrice       Decimal            @db.Decimal(10, 3)
  promotionalPrice     Decimal?           @db.Decimal(10, 3)
  compareAtPrice       Decimal?           @db.Decimal(10, 3)
  lowStockThreshold    Int                @default(5)
  isFeatured           Boolean            @default(false)
  isActive             Boolean            @default(true)
  seoTitle             String?
  seoDescription       String?
  categoryId           String
  category             Category           @relation(fields: [categoryId], references: [id])
  brandId              String?
  brand                Brand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  preferredSupplierId  String?
  preferredSupplier    Supplier?          @relation("PreferredSupplier", fields: [preferredSupplierId], references: [id], onDelete: SetNull)
  images               ProductImage[]
  variants             ProductVariant[]
  priceTiers           ProductPriceTier[]
  supplierOfferings    SupplierProduct[]
  inventory            Inventory?
  stockMovements       StockMovement[]
  inventoryLogs        InventoryLog[]
  orderItems           OrderItem[]
  cartItems            CartItem[]
  invoiceItems         InvoiceItem[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  @@index([categoryId, isActive])
  @@index([brandId])
  @@index([preferredSupplierId])
  @@index([deletedAt])
}

model ProductImage {
  id        String          @id @default(cuid())
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  url       String
  altText   String?
  sortOrder Int             @default(0)
  isPrimary Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([productId, sortOrder])
  @@index([variantId])
}

model ProductVariant {
  id               String             @id @default(cuid())
  productId        String
  product          Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku              String             @unique
  title            String
  attributes       Json
  barcode          String?
  costPrice        Decimal?           @db.Decimal(10, 3)
  retailPrice      Decimal?           @db.Decimal(10, 3)
  wholesalePrice   Decimal?           @db.Decimal(10, 3)
  quantityOnHand   Int                @default(0)
  reservedQuantity Int                @default(0)
  weightGrams      Int?
  isActive         Boolean            @default(true)
  images           ProductImage[]
  priceTiers       ProductPriceTier[]
  stockMovements   StockMovement[]
  inventoryLogs    InventoryLog[]
  orderItems       OrderItem[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  @@index([productId, isActive])
  @@index([deletedAt])
}

model ProductPriceTier {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  label        String
  minQuantity  Int
  maxQuantity  Int?
  price        Decimal         @db.Decimal(10, 3)
  customerType CustomerType    @default(WHOLESALE)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([productId, variantId, customerType, minQuantity, label])
  @@index([productId, minQuantity])
}

model SupplierProduct {
  id                   String   @id @default(cuid())
  supplierId           String
  supplier             Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productId            String
  product              Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierSku          String?
  costPrice            Decimal  @db.Decimal(10, 3)
  leadTimeDays         Int?
  minimumOrderQuantity Int      @default(1)
  isPreferred          Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([supplierId, productId])
  @@index([productId, isPreferred])
}

model InventoryLog {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  logDate      DateTime
  openingStock Int
  stockIn      Int             @default(0)
  stockOut     Int             @default(0)
  adjustments  Int             @default(0)
  closingStock Int
  reorderPoint Int?
  stockValue   Decimal?        @db.Decimal(14, 2)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([productId, logDate(sort: Desc)])
  @@index([variantId, logDate(sort: Desc)])
}

model StockMovement {
  id             String            @id @default(cuid())
  productId      String
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId      String?
  variant        ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  supplierId     String?
  supplier       Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  orderId        String?
  order          Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type           StockMovementType
  reference      String?
  quantityChange Int
  quantityBefore Int
  quantityAfter  Int
  unitCost       Decimal?          @db.Decimal(10, 3)
  notes          String?
  performedById  String?
  performedBy    User?             @relation("MovementsPerformed", fields: [performedById], references: [id], onDelete: SetNull)
  createdAt      DateTime          @default(now())

  @@index([productId, createdAt(sort: Desc)])
  @@index([variantId, createdAt(sort: Desc)])
  @@index([orderId])
  @@index([supplierId])
}

model Order {
  id                  String                     @id @default(cuid())
  orderNumber         String                     @unique
  customerId          String?
  customer            Customer?                  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdById         String?
  createdBy           User?                      @relation("OrdersCreated", fields: [createdById], references: [id], onDelete: SetNull)
  shippingAddressId   String?
  shippingAddress     Address?                   @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  billingAddressId    String?
  billingAddress      Address?                   @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
  channel             OrderChannel               @default(B2B_PORTAL)
  currency            String                     @default("TND")
  status              OrderStatus                @default(PENDING)
  fulfillmentStatus   FulfillmentStatus          @default(CONFIRMED)
  packagingStatus     PackagingStatus            @default(NOT_STARTED)
  deliveryStatus      DeliveryStatus             @default(NOT_ASSIGNED)
  paymentStatus       PaymentStatus              @default(PENDING)
  paymentMethod       PaymentMethod              @default(CASH_ON_DELIVERY)
  subtotal            Decimal                    @db.Decimal(14, 2)
  discountTotal       Decimal                    @default(0) @db.Decimal(14, 2)
  shippingFee         Decimal                    @default(0) @db.Decimal(14, 2)
  taxTotal            Decimal                    @default(0) @db.Decimal(14, 2)
  total               Decimal                    @db.Decimal(14, 2)
  costTotal           Decimal                    @default(0) @db.Decimal(14, 2)
  profitEstimate      Decimal                    @default(0) @db.Decimal(14, 2)
  itemsCount          Int                        @default(0)
  receiverName        String
  receiverCompany     String?
  receiverPhone       String
  receiverEmail       String?
  receiverAddressLine String
  receiverCity        String
  receiverGovernorate String
  receiverPostalCode  String?
  billingName         String?
  billingPhone        String?
  billingEmail        String?
  billingAddressLine  String?
  billingCity         String?
  billingGovernorate  String?
  billingPostalCode   String?
  customerNotes       String?
  internalNotes       String?
  paymentReference    String?
  placedAt            DateTime                   @default(now())
  fulfilledAt         DateTime?
  packedAt            DateTime?
  dispatchedAt        DateTime?
  deliveredAt         DateTime?
  cancelledAt         DateTime?
  items               OrderItem[]
  payments            Payment[]
  invoice             Invoice?
  delivery            Delivery?
  fulfillmentHistory  FulfillmentStatusHistory[]
  packagingHistory    PackagingStatusHistory[]
  notifications       Notification[]
  stockMovements      StockMovement[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  deletedAt           DateTime?

  @@index([customerId, createdAt(sort: Desc)])
  @@index([status, paymentStatus])
  @@index([deletedAt])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  productName     String
  productSlug     String?
  productImageUrl String?
  sku             String
  unitCost        Decimal         @db.Decimal(10, 3)
  unitPrice       Decimal         @db.Decimal(10, 3)
  quantity        Int
  discountTotal   Decimal         @default(0) @db.Decimal(12, 2)
  total           Decimal         @db.Decimal(14, 2)

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                   String        @id @default(cuid())
  orderId              String
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount               Decimal       @db.Decimal(14, 2)
  currency             String        @default("TND")
  method               PaymentMethod
  status               PaymentStatus @default(PENDING)
  provider             String?
  providerReference    String?
  transactionReference String?
  paidAt               DateTime?
  dueAt                DateTime?
  notes                String?
  receivedById         String?
  receivedBy           User?         @relation("PaymentsReceived", fields: [receivedById], references: [id], onDelete: SetNull)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([orderId, status])
  @@index([paidAt(sort: Desc)])
}

model Expense {
  id           String          @id @default(cuid())
  supplierId   String?
  supplier     Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  recordedById String?
  recordedBy   User?           @relation("ExpensesRecorded", fields: [recordedById], references: [id], onDelete: SetNull)
  title        String
  category     ExpenseCategory
  amount       Decimal         @db.Decimal(14, 2)
  expenseDate  DateTime
  reference    String?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  @@index([category, expenseDate(sort: Desc)])
  @@index([supplierId])
  @@index([deletedAt])
}

model CustomerProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId        String?   @unique
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  firstName         String?
  lastName          String?
  preferredLanguage String    @default("fr")
  marketingOptIn    Boolean   @default(false)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Inventory {
  id                String    @id @default(cuid())
  productId         String    @unique
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  currentStock      Int       @default(0)
  reservedStock     Int       @default(0)
  soldStock         Int       @default(0)
  damagedStock      Int       @default(0)
  lowStockThreshold Int       @default(5)
  reorderPoint      Int?
  lastCountedAt     DateTime?
  lastRestockedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Cart {
  id             String     @id @default(cuid())
  userId         String?
  user           User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerId     String?
  customer       Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status         CartStatus @default(ACTIVE)
  currency       String     @default("TND")
  subtotal       Decimal    @default(0) @db.Decimal(14, 2)
  shippingAmount Decimal    @default(0) @db.Decimal(14, 2)
  total          Decimal    @default(0) @db.Decimal(14, 2)
  convertedAt    DateTime?
  abandonedAt    DateTime?
  items          CartItem[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId, status])
  @@index([customerId, status])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 3)
  total     Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([productId])
}

model Invoice {
  id               String        @id @default(cuid())
  invoiceNumber    String        @unique
  orderId          String        @unique
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId       String?
  customer         Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  billingAddressId String?
  billingAddress   Address?      @relation("InvoiceBillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
  status           InvoiceStatus @default(ISSUED)
  issueDate        DateTime      @default(now())
  dueDate          DateTime?
  currency         String        @default("TND")
  subtotal         Decimal       @db.Decimal(14, 2)
  shippingAmount   Decimal       @default(0) @db.Decimal(14, 2)
  taxAmount        Decimal       @default(0) @db.Decimal(14, 2)
  total            Decimal       @db.Decimal(14, 2)
  notes            String?
  items            InvoiceItem[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([customerId, issueDate(sort: Desc)])
}

model InvoiceItem {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  label     String
  sku       String?
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 3)
  total     Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([productId])
}

model FulfillmentStatusHistory {
  id          String            @id @default(cuid())
  orderId     String
  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      FulfillmentStatus
  note        String?
  changedById String?
  changedAt   DateTime          @default(now())

  @@index([orderId, changedAt(sort: Desc)])
}

model PackagingStatusHistory {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      PackagingStatus
  note        String?
  changedById String?
  changedAt   DateTime        @default(now())

  @@index([orderId, changedAt(sort: Desc)])
}

model Delivery {
  id                    String                  @id @default(cuid())
  orderId               String                  @unique
  order                 Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId            String?
  customer              Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  addressId             String?
  address               Address?                @relation("DeliveryAddress", fields: [addressId], references: [id], onDelete: SetNull)
  method                DeliveryMethod          @default(STANDARD)
  courierName           String?
  courierCompany        String?
  trackingNumber        String?                 @unique
  status                DeliveryStatus          @default(NOT_ASSIGNED)
  dispatchDate          DateTime?
  estimatedDeliveryDate DateTime?
  completedAt           DateTime?
  notes                 String?
  receiverName          String?
  receiverPhone         String?
  events                DeliveryTrackingEvent[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([status, dispatchDate(sort: Desc)])
  @@index([customerId])
}

model DeliveryTrackingEvent {
  id          String         @id @default(cuid())
  deliveryId  String
  delivery    Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  status      DeliveryStatus
  location    String?
  description String?
  eventAt     DateTime       @default(now())

  @@index([deliveryId, eventAt(sort: Desc)])
}

model AuditLog {
  id           String      @id @default(cuid())
  actorId      String?
  actor        User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action       AuditAction
  resourceType String
  resourceId   String
  description  String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([resourceType, resourceId])
  @@index([actorId, createdAt(sort: Desc)])
}

model Notification {
  id         String              @id @default(cuid())
  userId     String?
  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerId String?
  customer   Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderId    String?
  order      Order?              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  channel    NotificationChannel
  status     NotificationStatus  @default(PENDING)
  title      String
  body       String
  sentAt     DateTime?
  readAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([userId, status])
  @@index([customerId, status])
  @@index([orderId])
}

model FinancialReport {
  id               String     @id @default(cuid())
  reportType       ReportType
  name             String
  periodStart      DateTime
  periodEnd        DateTime
  currency         String     @default("TND")
  generatedById    String?
  generatedBy      User?      @relation("ReportsCreated", fields: [generatedById], references: [id], onDelete: SetNull)
  summary          Json
  generatedPdfPath String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([reportType, periodStart, periodEnd])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
