generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleKey {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

enum CustomerType {
  WHOLESALE
  RETAIL
  INSTITUTIONAL
}

enum AddressType {
  BILLING
  SHIPPING
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PICKING
  READY_FOR_DELIVERY
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum OrderChannel {
  B2B_PORTAL
  DIRECT_SALES
  SHOWROOM
  WHATSAPP
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  BANK_TRANSFER
  CHEQUE
  CARD
  WALLET
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN_IN
  RETURN_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGE
  TRANSFER_IN
  TRANSFER_OUT
  COUNT_CORRECTION
}

enum ExpenseCategory {
  OPERATIONS
  LOGISTICS
  MARKETING
  PAYROLL
  RENT
  UTILITIES
  OTHER
}

model Role {
  id          Int      @id @default(autoincrement())
  key         RoleKey  @unique
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  phone            String?
  passwordHash     String?
  isActive         Boolean           @default(true)
  roleId           Int
  role             Role              @relation(fields: [roleId], references: [id])
  customerId       String?           @unique
  customer         Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lastLoginAt      DateTime?
  accounts         Account[]
  sessions         Session[]
  ordersCreated    Order[]           @relation("OrdersCreated")
  stockMovements   StockMovement[]   @relation("MovementsPerformed")
  paymentsReceived Payment[]         @relation("PaymentsReceived")
  recordedExpenses Expense[]         @relation("ExpensesRecorded")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  @@index([roleId])
  @@index([deletedAt])
}

model Customer {
  id               String       @id @default(cuid())
  code             String       @unique
  type             CustomerType @default(WHOLESALE)
  companyName      String
  contactName      String
  email            String?
  phone            String
  alternatePhone   String?
  vatNumber        String?
  governorate      String?
  city             String?
  creditLimit      Decimal?     @db.Decimal(12, 2)
  paymentTermsDays Int          @default(0)
  lifetimeValue    Decimal      @default(0) @db.Decimal(14, 2)
  notes            String?
  isActive         Boolean      @default(true)
  user             User?
  addresses        Address[]
  orders           Order[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  @@index([type, isActive])
  @@index([deletedAt])
}

model Address {
  id             String      @id @default(cuid())
  customerId     String
  customer       Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type           AddressType
  label          String
  contactName    String?
  phone          String?
  line1          String
  line2          String?
  city           String
  governorate    String
  postalCode     String?
  country        String      @default("Tunisia")
  isDefault      Boolean     @default(false)
  ordersShipping Order[]     @relation("ShippingAddress")
  ordersBilling  Order[]     @relation("BillingAddress")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  @@index([customerId, type])
  @@index([deletedAt])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([parentId])
  @@index([deletedAt])
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  country     String?
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Supplier {
  id                String            @id @default(cuid())
  code              String            @unique
  name              String
  slug              String            @unique
  contactName       String?
  email             String?
  phone             String?
  line1             String?
  city              String?
  governorate       String?
  paymentTermsDays  Int               @default(0)
  notes             String?
  preferredProducts Product[]         @relation("PreferredSupplier")
  offerings         SupplierProduct[]
  stockMovements    StockMovement[]
  expenses          Expense[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  @@index([deletedAt])
}

model Product {
  id                   String            @id @default(cuid())
  sku                  String            @unique
  barcode              String?
  slug                 String            @unique
  name                 String
  shortDescription     String?
  description          String?
  unit                 String            @default("piece")
  packSize             Int               @default(1)
  minimumOrderQuantity Int               @default(1)
  stockOnHand          Int               @default(0)
  costPrice            Decimal           @db.Decimal(10, 3)
  retailPrice          Decimal           @db.Decimal(10, 3)
  wholesalePrice       Decimal           @db.Decimal(10, 3)
  lowStockThreshold    Int               @default(5)
  isFeatured           Boolean           @default(false)
  isActive             Boolean           @default(true)
  categoryId           String
  category             Category          @relation(fields: [categoryId], references: [id])
  brandId              String?
  brand                Brand?            @relation(fields: [brandId], references: [id], onDelete: SetNull)
  preferredSupplierId  String?
  preferredSupplier    Supplier?         @relation("PreferredSupplier", fields: [preferredSupplierId], references: [id], onDelete: SetNull)
  images               ProductImage[]
  variants             ProductVariant[]
  priceTiers           ProductPriceTier[]
  supplierOfferings    SupplierProduct[]
  stockMovements       StockMovement[]
  inventoryLogs        InventoryLog[]
  orderItems           OrderItem[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  deletedAt            DateTime?

  @@index([categoryId, isActive])
  @@index([brandId])
  @@index([preferredSupplierId])
  @@index([deletedAt])
}

model ProductImage {
  id        String          @id @default(cuid())
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  url       String
  altText   String?
  sortOrder Int             @default(0)
  isPrimary Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([productId, sortOrder])
  @@index([variantId])
}

model ProductVariant {
  id               String            @id @default(cuid())
  productId        String
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku              String            @unique
  title            String
  attributes       Json
  barcode          String?
  costPrice        Decimal?          @db.Decimal(10, 3)
  retailPrice      Decimal?          @db.Decimal(10, 3)
  wholesalePrice   Decimal?          @db.Decimal(10, 3)
  quantityOnHand   Int               @default(0)
  reservedQuantity Int               @default(0)
  weightGrams      Int?
  isActive         Boolean           @default(true)
  images           ProductImage[]
  priceTiers       ProductPriceTier[]
  stockMovements   StockMovement[]
  inventoryLogs    InventoryLog[]
  orderItems       OrderItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  @@index([productId, isActive])
  @@index([deletedAt])
}

model ProductPriceTier {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  label        String
  minQuantity  Int
  maxQuantity  Int?
  price        Decimal         @db.Decimal(10, 3)
  customerType CustomerType    @default(WHOLESALE)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([productId, minQuantity])
  @@unique([productId, variantId, customerType, minQuantity, label])
}

model SupplierProduct {
  id                   String   @id @default(cuid())
  supplierId           String
  supplier             Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productId            String
  product              Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierSku          String?
  costPrice            Decimal  @db.Decimal(10, 3)
  leadTimeDays         Int?
  minimumOrderQuantity Int      @default(1)
  isPreferred          Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([supplierId, productId])
  @@index([productId, isPreferred])
}

model InventoryLog {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId    String?
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  logDate      DateTime
  openingStock Int
  stockIn      Int             @default(0)
  stockOut     Int             @default(0)
  adjustments  Int             @default(0)
  closingStock Int
  reorderPoint Int?
  stockValue   Decimal?        @db.Decimal(14, 2)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([productId, logDate(sort: Desc)])
  @@index([variantId, logDate(sort: Desc)])
}

model StockMovement {
  id             String            @id @default(cuid())
  productId      String
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId      String?
  variant        ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  supplierId     String?
  supplier       Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  orderId        String?
  order          Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type           StockMovementType
  reference      String?
  quantityChange Int
  quantityBefore Int
  quantityAfter  Int
  unitCost       Decimal?          @db.Decimal(10, 3)
  notes          String?
  performedById  String?
  performedBy    User?             @relation("MovementsPerformed", fields: [performedById], references: [id], onDelete: SetNull)
  createdAt      DateTime          @default(now())

  @@index([productId, createdAt(sort: Desc)])
  @@index([variantId, createdAt(sort: Desc)])
  @@index([orderId])
  @@index([supplierId])
}

model Order {
  id                  String        @id @default(cuid())
  orderNumber         String        @unique
  customerId          String?
  customer            Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdById         String?
  createdBy           User?         @relation("OrdersCreated", fields: [createdById], references: [id], onDelete: SetNull)
  shippingAddressId   String?
  shippingAddress     Address?      @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  billingAddressId    String?
  billingAddress      Address?      @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)
  channel             OrderChannel  @default(B2B_PORTAL)
  currency            String        @default("TND")
  status              OrderStatus   @default(PENDING)
  paymentStatus       PaymentStatus @default(PENDING)
  paymentMethod       PaymentMethod @default(CASH_ON_DELIVERY)
  subtotal            Decimal       @db.Decimal(14, 2)
  discountTotal       Decimal       @default(0) @db.Decimal(14, 2)
  shippingFee         Decimal       @default(0) @db.Decimal(14, 2)
  taxTotal            Decimal       @default(0) @db.Decimal(14, 2)
  total               Decimal       @db.Decimal(14, 2)
  costTotal           Decimal       @default(0) @db.Decimal(14, 2)
  profitEstimate      Decimal       @default(0) @db.Decimal(14, 2)
  itemsCount          Int           @default(0)
  receiverName        String
  receiverCompany     String?
  receiverPhone       String
  receiverEmail       String?
  receiverAddressLine String
  receiverCity        String
  receiverGovernorate String
  customerNotes       String?
  internalNotes       String?
  placedAt            DateTime      @default(now())
  fulfilledAt         DateTime?
  cancelledAt         DateTime?
  items               OrderItem[]
  payments            Payment[]
  stockMovements      StockMovement[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@index([customerId, createdAt(sort: Desc)])
  @@index([status, paymentStatus])
  @@index([deletedAt])
}

model OrderItem {
  id            String          @id @default(cuid())
  orderId       String
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  productName   String
  sku           String
  unitCost      Decimal         @db.Decimal(10, 3)
  unitPrice     Decimal         @db.Decimal(10, 3)
  quantity      Int
  discountTotal Decimal         @default(0) @db.Decimal(12, 2)
  total         Decimal         @db.Decimal(14, 2)

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                   String        @id @default(cuid())
  orderId              String
  order                Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount               Decimal       @db.Decimal(14, 2)
  method               PaymentMethod
  status               PaymentStatus @default(PENDING)
  transactionReference String?
  paidAt               DateTime?
  dueAt                DateTime?
  notes                String?
  receivedById         String?
  receivedBy           User?         @relation("PaymentsReceived", fields: [receivedById], references: [id], onDelete: SetNull)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([orderId, status])
  @@index([paidAt(sort: Desc)])
}

model Expense {
  id           String          @id @default(cuid())
  supplierId   String?
  supplier     Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  recordedById String?
  recordedBy   User?           @relation("ExpensesRecorded", fields: [recordedById], references: [id], onDelete: SetNull)
  title        String
  category     ExpenseCategory
  amount       Decimal         @db.Decimal(14, 2)
  expenseDate  DateTime
  reference    String?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  @@index([category, expenseDate(sort: Desc)])
  @@index([supplierId])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
